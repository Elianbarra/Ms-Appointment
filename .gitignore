# =============================================================================
# .gitignore — ms-appointment (Spring Boot + Gradle + K8s)
# =============================================================================

# ── Gradle ────────────────────────────────────────────────────────────────────
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# ── Java ──────────────────────────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# ── Spring Boot ───────────────────────────────────────────────────────────────
spring-shell.log
target/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
*.log.*
logs/

# ── Secretos y variables de entorno ───────────────────────────────────────────
.env
.env.*
!.env.example            # El ejemplo SÍ se sube (sin valores reales)
*.pem
*.key
*.p12
*.jks
*.pkcs12
*.keystore
*.truststore

# ── Kubernetes — secretos aplicados ───────────────────────────────────────────
# Nunca subir secrets con valores reales. Sube solo la plantilla (secret.yaml
# con valores de ejemplo), o nómbralos con sufijo .local.yaml y exclúyelos:
k8s/*.local.yaml
k8s/*.secret.yaml

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore

# ── IntelliJ IDEA ─────────────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
out/
!.idea/codeStyles/
!.idea/inspectionProfiles/

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ── Eclipse ───────────────────────────────────────────────────────────────────
.classpath
.project
.settings/
bin/

# ── NetBeans ──────────────────────────────────────────────────────────────────
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/

# ── STS (Spring Tool Suite) ───────────────────────────────────────────────────
.apt_generated
.factorypath

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Linux ─────────────────────────────────────────────────────────────────────
*~

# ── Cobertura y reportes de test ──────────────────────────────────────────────
.jacoco/
jacoco.exec
.sonar/
.sonarqube/
test-results/

# ── Herramientas de build temporales ──────────────────────────────────────────
.cache/
tmp/
temp/
